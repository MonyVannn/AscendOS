# Neon (PostgreSQL) — replace USER, PASSWORD, HOST with values from https://console.neon.tech
# Pooled or serverless URL for the Next.js app (used by `src/lib/db.ts`)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Direct (non-pooled) URL for Prisma CLI migrations; optional if you use one URL for everything
DIRECT_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Clerk — https://dashboard.clerk.com/last-active?path=api-keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Optional: custom sign-in/up URLs when not using Clerk hosted defaults
# NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
# NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
