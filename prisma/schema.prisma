// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Application user keyed by Clerk `user_…` id (extend or sync via webhooks as needed).
model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agencyId  String?
  agency    Agency?  @relation(fields: [agencyId], references: [id])
}

model Agency {
  id            String       @id @default(cuid())
  name          String
  slug          String       @unique
  ghlWebhookUrl String
  ghlApiKey     String
  featuresArray Json         @default("[]")
  createdAt     DateTime     @default(now())

  theme         AgencyTheme?
  users         User[]
  webhookLogs   WebhookLog[]
}

model AgencyTheme {
  id              String   @id @default(cuid())
  agencyId        String   @unique
  primaryColor    String   @default("#000000")
  accentColor     String   @default("#6366f1")
  backgroundColor String   @default("#ffffff")
  sidebarColor    String   @default("#1e1e2e")
  textColor       String   @default("#111111")
  logoUrl         String?
  faviconUrl      String?
  fontFamily      String   @default("Inter")
  borderRadius    String   @default("8px")
  dashboardTitle  String   @default("Command Center")
  updatedAt       DateTime @updatedAt

  agency          Agency   @relation(fields: [agencyId], references: [id])
}

model WebhookLog {
  id        String   @id @default(cuid())
  agencyId  String
  payload   Json?
  createdAt DateTime @default(now())

  agency    Agency   @relation(fields: [agencyId], references: [id])
}
